{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowReadFromSpecificWorkloadRole",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::123456789012:role/course-web-readonly"
      },
      "Action": [
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::docker-course-example/*"
    }
  ]
}
