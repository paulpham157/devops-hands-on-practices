{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ListCourseBucket",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::docker-course-example"
    },
    {
      "Sid": "ReadCourseBucketObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::docker-course-example/*"
    }
  ]
}
