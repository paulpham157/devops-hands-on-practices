{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "TrustAuditRoleFromSecurityAccount",
      "Effect": "Allow",
      "Principal": {
        "AWS": "arn:aws:iam::111111111111:role/security-audit"
      },
      "Action": "sts:AssumeRole",
      "Condition": {
        "StringEquals": {
          "sts:ExternalId": "replace-with-shared-external-id"
        }
      }
    }
  ]
}
