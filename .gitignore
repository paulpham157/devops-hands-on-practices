.DS_Store
.idea/
.vscode/

# Python local cache
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Node / JavaScript local dependencies and logs
node_modules/
.npm/
.pnpm-store/
dist/
coverage/
.nyc_output/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Java, Gradle, Maven, Go, and Rust build output
target/
.gradle/
build/
bin/
*.class
*.jar
*.war

# Local environment files
.env
.env.*
!.env.example
!.env.*.example

# Docker Compose local overrides
compose.override.yaml
compose.override.yml
docker-compose.override.yaml
docker-compose.override.yml

# Terraform local state and plugin cache
.terraform/
.tofu/
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info
*.tfplan
*.tfplan.json
*.tfvars
*.tfvars.json
crash.log

# Kubernetes local credentials and generated config
kubeconfig
kubeconfig.*
*.kubeconfig

# Helm packaged chart output
*.tgz

# Security scanner local cache and generated reports
.trivy-cache/
.scannerwork/
.jfrog/
.snyk-cache/
[0-9][0-9]-*/reports/
[0-9][0-9]-*/artifacts/
[0-9][0-9]-*/sandbox/

# Lesson-generated local secrets
13-vaults-and-secrets-managers/secrets/*.txt
!13-vaults-and-secrets-managers/secrets/*.example.txt

# Packer local output
packer_cache/
*.pkrvars.hcl
